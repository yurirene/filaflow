APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Docker (docker compose up)
# APP_PORT=8081
# APP_URL=http://localhost:8081
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=filaflow
# DB_USERNAME=filaflow
# DB_PASSWORD=secret
# DOCKER_MYSQL_DATABASE=filaflow
# DOCKER_MYSQL_USER=filaflow
# DOCKER_MYSQL_PASSWORD=secret
# MYSQL_ROOT_PASSWORD=rootsecret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=filaflow
PUSHER_APP_KEY=filaflow-key
PUSHER_APP_SECRET=filaflow-secret
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# Echo (navegador): sempre host público — localhost fora do Docker, mesmo domínio em produção
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST=localhost
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME=http
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SOKETI_PORT=6001
SOKETI_DEBUG=0
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Clínica (tabela empresas — configuração única da fila)
FILA_CLINICA_NOME="${APP_NAME}"
FILA_CLINICA_CNPJ=
FILA_CLINICA_ATIVO=true
FILA_CLINICA_HORA_INICIO=07:00
FILA_CLINICA_HORA_FIM=19:00
FILA_CLINICA_TICKER="Bem-vindo! Traga seus documentos e exames anteriores."
FILA_CLINICA_REINICIO_HORA=00:00
FILA_CLINICA_SOM=beep

# Dados de demonstração (alas, serviços, guichês, consultórios, senhas)
FILA_SEED_DEMO=true

